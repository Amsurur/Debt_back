# Server
NODE_ENV=development
PORT=4000

# Database (local example; on Railway/Render this is provided automatically)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/debt_tracker
# Set to true on Render / managed Postgres that requires SSL. Keep false locally.
PGSSL=false

# JWT secrets — generate long random strings (see README)
ACCESS_TOKEN_SECRET=change_me_access_secret_please
REFRESH_TOKEN_SECRET=change_me_refresh_secret_please
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# CORS: "*" for all, or comma-separated origins e.g. https://myapp.com,https://app2.com
CORS_ORIGIN=*
